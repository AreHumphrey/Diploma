\RequirePackage{graphicx}
\RequirePackage{multicol}
\RequirePackage{array}

\newcommand{\uline}[1]{\underline{#1\vphantom{lp}}}

\newcommand{\usersignature}[1]{
    \(
        \underset{\textit{(Ф.И.О.)}}{\uline{~ \text{#1} ~}}
    \)
    \(
        \underset{\textit{(подпись)}}{\uline{\hspace{50pt}}}
    \)
}

\newcommand{\fakedocdate}[3]{
    <<\uline{#1}>> \uline{~\monthname{#2}~} 20\uline{\DTMtwodigits{#3}}~г.
}

\newcommand{\docdate}{
    <<\uline{~\the\day~}>> \uline{~\monthname{\the\month}~} 20\uline{\DTMtwodigits{\the\year}}~г.
}

% Пустые поля для подписей на титульнике курсовой
\newcommand{\blankdate}{%
    <<\uline{\hspace{12pt}}>>~\uline{\hspace{52pt}}~20\uline{\hspace{12pt}}~г.%
}

